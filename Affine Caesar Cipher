#include <stdio.h>
#include <ctype.h>

int main() {
    char text[100];
    int a, b, i;

    printf("Enter Plaintext: ");
    scanf("%[^\n]", text);

    printf("Enter value of a: ");
    scanf("%d", &a);

    printf("Enter value of b: ");
    scanf("%d", &b);

    if(a!=1 && a!=3 && a!=5 && a!=7 && a!=9 &&
       a!=11 && a!=15 && a!=17 && a!=19 &&
       a!=21 && a!=23 && a!=25)
    {
        printf("Invalid value of a.\n");
        return 0;
    }

    for(i=0;text[i]!='\0';i++)
    {
        if(isupper(text[i]))
            text[i]=((a*(text[i]-'A')+b)%26)+'A';
        else if(islower(text[i]))
            text[i]=((a*(text[i]-'a')+b)%26)+'a';
    }

    printf("Cipher Text: %s",text);

    return 0;
}
