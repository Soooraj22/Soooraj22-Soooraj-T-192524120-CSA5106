#include <stdio.h>
#include <string.h>
#include <ctype.h>

char matrix[5][5];
int used[26];

// Generate Playfair matrix
void generateMatrix(char key[]) {
    int i, j, k = 0;
    char temp[25];

    memset(used, 0, sizeof(used));

    for (i = 0; key[i] != '\0'; i++) {
        char ch = toupper(key[i]);
        if (ch == 'J')
            ch = 'I';

        if (ch >= 'A' && ch <= 'Z' && !used[ch - 'A']) {
            used[ch - 'A'] = 1;
            temp[k++] = ch;
        }
    }

    for (i = 0; i < 26; i++) {
        if (i == 9)   // Skip J
            continue;
        if (!used[i])
            temp[k++] = i + 'A';
    }

    k = 0;
    for (i = 0; i < 5; i++)
        for (j = 0; j < 5; j++)
            matrix[i][j] = temp[k++];
}

// Find position of character in matrix
void findPosition(char ch, int *row, int *col) {
    if (ch == 'J')
        ch = 'I';

    int i, j;
    for (i = 0; i < 5; i++) {
        for (j = 0; j < 5; j++) {
            if (matrix[i][j] == ch) {
                *row = i;
                *col = j;
                return;
            }
        }
    }
}

int main() {
    char key[50], text[100], prepared[100];
    int i, j = 0;

    printf("Enter keyword: ");
    scanf("%s", key);

    printf("Enter plaintext: ");
    scanf(" %[^\n]", text);

    generateMatrix(key);

    // Prepare plaintext
    for (i = 0; text[i] != '\0'; i++) {
        if (isalpha(text[i])) {
            prepared[j++] = toupper(text[i]);
        }
    }
    prepared[j] = '\0';

    // Insert X between repeated letters
    char finalText[100];
    int len = 0;

    for (i = 0; prepared[i] != '\0'; i++) {
        finalText[len++] = prepared[i];
        if (prepared[i] == prepared[i + 1]) {
            finalText[len++] = 'X';
        }
    }

    if (len % 2 != 0)
        finalText[len++] = 'X';

    finalText[len] = '\0';

    printf("\nCiphertext: ");

    for (i = 0; i < len; i += 2) {
        int r1, c1, r2, c2;
        findPosition(finalText[i], &r1, &c1);
        findPosition(finalText[i + 1], &r2, &c2);

        if (r1 == r2) {
            printf("%c%c",
                   matrix[r1][(c1 + 1) % 5],
                   matrix[r2][(c2 + 1) % 5]);
        }
        else if (c1 == c2) {
            printf("%c%c",
                   matrix[(r1 + 1) % 5][c1],
                   matrix[(r2 + 1) % 5][c2]);
        }
        else {
            printf("%c%c",
                   matrix[r1][c2],
                   matrix[r2][c1]);
        }
    }

    printf("\n");

    return 0;
}
