#include <stdio.h>

int modInverse(int a)
{
    int i;
    for(i=1;i<26;i++)
        if((a*i)%26==1)
            return i;
    return -1;
}

int main()
{
    int key[2][2]={{9,4},{5,7}};
    char plain[100];
    int i;

    printf("Enter Plaintext (uppercase): ");
    scanf("%s",plain);

    printf("Ciphertext: ");

    for(i=0;plain[i]!='\0';i+=2)
    {
        int p1=plain[i]-'A';
        int p2=plain[i+1]-'A';

        int c1=(key[0][0]*p1+key[0][1]*p2)%26;
        int c2=(key[1][0]*p1+key[1][1]*p2)%26;

        printf("%c%c",c1+'A',c2+'A');
    }

    printf("\n");

    return 0;
}
