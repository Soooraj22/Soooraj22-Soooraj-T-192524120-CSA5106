#include <stdio.h>
#include <string.h>

int main()
{
    char plain[100];
    int key[100],i,n;

    printf("Enter Plaintext (uppercase): ");
    scanf("%s",plain);

    n=strlen(plain);

    printf("Enter %d key values:\n",n);

    for(i=0;i<n;i++)
        scanf("%d",&key[i]);

    printf("Ciphertext: ");

    for(i=0;i<n;i++)
        printf("%c",((plain[i]-'A'+key[i])%26)+'A');

    return 0;
}
