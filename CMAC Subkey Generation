#include <stdio.h>

int main() {
    unsigned long long L, K1, K2;
    int blockSize;

    printf("Enter Block Size (64 or 128): ");
    scanf("%d", &blockSize);

    printf("Enter Initial Value (Hex): ");
    scanf("%llx", &L);

    if (blockSize == 64) {
        K1 = (L << 1);
        if (L & 0x8000000000000000)
            K1 ^= 0x1B;

        K2 = (K1 << 1);
        if (K1 & 0x8000000000000000)
            K2 ^= 0x1B;
    } else {
        K1 = (L << 1);
        if (L & 0x8000000000000000)
            K1 ^= 0x87;

        K2 = (K1 << 1);
        if (K1 & 0x8000000000000000)
            K2 ^= 0x87;
    }

    printf("\nSubkey K1 = %llX", K1);
    printf("\nSubkey K2 = %llX", K2);

    return 0;
}
