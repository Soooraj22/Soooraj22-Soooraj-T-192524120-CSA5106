#include <stdio.h>
#include <string.h>

int main()
{
    char cipher[100];
    int key,i;

    printf("Enter Ciphertext: ");
    scanf("%s",cipher);

    printf("Possible Plaintexts:\n\n");

    for(key=0;key<26;key++)
    {
        printf("Key %2d : ",key);

        for(i=0;cipher[i]!='\0';i++)
            printf("%c",((cipher[i]-'A'-key+26)%26)+'A');

        printf("\n");
    }

    return 0;
}
