#include <stdio.h>

int gcd(int a,int b)
{
    while(b!=0)
    {
        int t=b;
        b=a%b;
        a=t;
    }
    return a;
}

int main()
{
    int p=59,q=61;
    int n=p*q;
    int phi=(p-1)*(q-1);
    int e=31,d;

    for(d=1;d<phi;d++)
        if((d*e)%phi==1)
            break;

    printf("p = %d\n",p);
    printf("q = %d\n",q);
    printf("n = %d\n",n);
    printf("phi = %d\n",phi);
    printf("Public Key  = (%d,%d)\n",e,n);
    printf("Private Key = (%d,%d)\n",d,n);

    return 0;
}
